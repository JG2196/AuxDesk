@inherits LayoutComponentBase

<!-- Bootstrap js plugin -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<div>
    <TopNavMenu />
</div>

<div class="page">
    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>

    <button @onclick="HideNav"><b>&lt;</b></button>

    <div style="display:@sidebarDisplay">
        <ToolsBar />
    </div>
</div>

@code {
    public string sidebarDisplay = "none";

    public void HideNav()
    {
        if (sidebarDisplay == "none")
        {
            sidebarDisplay = "";
            return;
        }

        sidebarDisplay = "none";
    }
}
