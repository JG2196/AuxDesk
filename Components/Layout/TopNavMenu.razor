<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="nav-item px-3">
        <NavLink class="nav-link" href="" @onclick="@(() => UpdateNavUI(0))" style="@navStyle_AuxDesk" Match="NavLinkMatch.All">
            <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span><b> AuxDesk</b>
        </NavLink>
    </div>
    <div class="nav-item px-3">
        <NavLink class="nav-link" @onclick="@(() => UpdateNavUI(1))" style="@navStyle_AllTasks" href="allTasks">
            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span><b> All Tasks</b>
        </NavLink>
    </div>
    <div class="nav-item px-3">
        <NavLink class="nav-link" @onclick="@(() => UpdateNavUI(2))" style="@navStyle_Recycle" href="recycle">
            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span><b> Recycle</b>
        </NavLink>
    </div>
</nav>

@code {
    private const string activeStyle = "color:#0dcaf0";

    public string navStyle_AuxDesk = activeStyle;
    public string navStyle_AllTasks = "";
    public string navStyle_Recycle = "";

    private void UpdateNavUI(int nav)
    {
        navStyle_AuxDesk = nav == 0 ? activeStyle : "";
        navStyle_AllTasks = nav == 1 ? activeStyle : "";
        navStyle_Recycle = nav == 2 ? activeStyle : "";
    }
}
