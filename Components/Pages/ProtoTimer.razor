@using AuxDesk.Services;

@inject ProtoITimerService _timerService
@implements IDisposable

@page "/prototimer"

<h3>Proto Timer</h3>
<br />
<div class="card border border-primary p-1 rounded-3" style="width:350px;border-color:#28c7fc !important;">
    <div class="card-body">
        <p class="fs-2 fw-bold text-center">@formattedTime</p>

        <div class="row justify-content-center mb-3">
            <div class="col-3">
                <button type="button" class="btn btn-sm fw-semibold" @onclick="@(() => SelectCountdown(2))" style="width:80px;@btn_1Hr">1 hr</button>
            </div>
            <div class="col-3">
                <button type="button" class="btn btn-sm fw-semibold" @onclick="@(() => SelectCountdown(1))" style="width:80px; @btn_30Mins">30 mins</button>
            </div>
            <div class="col-3">
                <button type="button" class="btn btn-sm fw-semibold" @onclick="@(() => SelectCountdown(0))" style="width:80px; @btn_15Mins">15 mins</button>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-3">
                <button type="button" class="btn fw-semibold" @onclick="StartTimer" style="width:70px; @btn_StartPause">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-play-fill" viewBox="0 0 16 16">
                        <path d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393" />
                    </svg><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pause-fill" viewBox="0 0 16 16">
                        <path d="M5.5 3.5A1.5 1.5 0 0 1 7 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5m5 0A1.5 1.5 0 0 1 12 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5" />
                    </svg>
                </button>
            </div>
            <div class="col-3">
                <button type="button" class="btn fw-semibold" @onclick="ResetTimer" style="width:70px; border:solid lightgrey 1px">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-clockwise" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                        <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466" />
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    public string formattedTime = string.Empty;
    public bool countdownIsRunning = false;
    public int selectedDuration = 1;

    string btn_30Mins = string.Empty;
    string btn_15Mins = string.Empty;
    string btn_1Hr = string.Empty;
    string btn_StartPause = "border:solid lightgrey 1px";

    string ui_BtnSelected = "color: black; background-color: #28c7fc";
    string ui_Btn = "border:solid lightgrey 1px";

    protected override void OnInitialized()
    {
        countdownIsRunning = _timerService.Countdown_IsRunning();

        _timerService.Countdown_OnTimerTick += UpdateTimerDisplay;
        _timerService.Countdown_OnTimerStateChanged += UpdateTimerState;

        SetCountdownUI(_timerService.Countdown_GetPresetTimer());

        if (countdownIsRunning)
        {
            btn_StartPause = ui_BtnSelected;
            formattedTime = _timerService.GetFormattedTime();
        }
        else
        {
            _timerService.SetTimer(1);
            btn_30Mins = ui_BtnSelected;
            //_timerService.SetTimer(selectedDuration);
            formattedTime = _timerService.GetFormattedTime();
        }
    }
    private void UpdateTimerDisplay()
    {
        formattedTime = _timerService.GetFormattedTime();
        InvokeAsync(StateHasChanged);
    }
    private void UpdateTimerState()
    {
        countdownIsRunning = _timerService.Countdown_IsRunning();
        btn_StartPause = countdownIsRunning ? ui_BtnSelected : ui_Btn;
        InvokeAsync(StateHasChanged);
    }
    public void SelectCountdown(int selectedTimer)
    {
        SetCountdownUI(selectedTimer);
        _timerService.SetTimer(selectedDuration);
        formattedTime = _timerService.GetFormattedTime();
    }
    public void SetCountdownUI(int selectedTimer)
    {
        btn_30Mins = ui_Btn;
        btn_15Mins = ui_Btn;
        btn_1Hr = ui_Btn;
        selectedDuration = selectedTimer;

        switch (selectedDuration)
        {
            case 0:
                btn_15Mins = ui_BtnSelected;
                break;
            case 1:
                btn_30Mins = ui_BtnSelected;
                break;
            case 2:
                btn_1Hr = ui_BtnSelected;
                break;
        }
    }
    public void StartTimer()
    {
        if (countdownIsRunning && !_timerService.Countdown_IsPaused())
        {
            _timerService.Countdown_PauseTimer();
            btn_StartPause = ui_Btn;
            return;
        }
        else
        {
            _timerService.Countdown_StartTimer();
        }
    }
    public void StopTimer()
    {
        _timerService.Countdown_StopTimer();
    }
    public void Dispose()
    {
        _timerService.Countdown_OnTimerTick -= UpdateTimerDisplay;
        _timerService.Countdown_OnTimerStateChanged -= UpdateTimerState;
    }
    private void ResetTimer()
    {
        try
        {
            countdownIsRunning = false;
            btn_StartPause = ui_Btn;
            _timerService.TimerCleanUp();
            _timerService.SetTimer(selectedDuration);
            formattedTime = _timerService.GetFormattedTime();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ResetTimer ex: {ex.Message}");
        }
    }
}
