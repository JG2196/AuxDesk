@using System.Timers;
@using Services;

@inject ITimerService _timerService

@page "/timerdev"

<div class="card border border-primary p-1 rounded-3" style="width:350px;border-color:#28c7fc !important;">
    <div class="card-body">
        <p class="fs-2 fw-bold text-center">@countdown_Hrs.ToString("D2"):@countdown_Mins.ToString("D2"):@countdown_Secs.ToString("D2")</p>

        <div class="row justify-content-center mb-3">
            <div class="col-3">
                <button type="button" class="btn btn-sm fw-semibold" @onclick="@(() => SelectDuration(2))" style="width:80px; @btn_1Hr" disabled="@bElementDisabled">1 hr</button>
            </div>
            <div class="col-3">
                <button type="button" class="btn btn-sm fw-semibold" @onclick="@(() => SelectDuration(1))" style="width:80px; @btn_30Mins" disabled="@bElementDisabled">30 mins</button>
            </div>
            <div class="col-3">
                <button type="button" class="btn btn-sm fw-semibold" @onclick="@(() => SelectDuration(0))" style="width:80px; @btn_15Mins" disabled="@bElementDisabled">15 mins</button>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-3">
                <button type="button" class="btn fw-semibold" @onclick="StartTimer" style="width:70px; @btn_StartPause">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-play-fill" viewBox="0 0 16 16">
                        <path d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393" />
                    </svg><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pause-fill" viewBox="0 0 16 16">
                        <path d="M5.5 3.5A1.5 1.5 0 0 1 7 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5m5 0A1.5 1.5 0 0 1 12 5v6a1.5 1.5 0 0 1-3 0V5a1.5 1.5 0 0 1 1.5-1.5" />
                    </svg>
                </button>
            </div>
            <div class="col-3">
                <button type="button" class="btn fw-semibold" @onclick="ResetTimer" style="width:70px; border:solid lightgrey 1px">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-clockwise" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                        <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466" />
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

@code {

    ///
    // Timer
    Timer? timer = null;

    int selectedDuration = 1;
    // For storing the set duration
    int setDuration_Hrs;
    int setDuration_Mins;
    int setDuration_Secs;

    // For countdown display
    int countdown_Hrs;
    int countdown_Mins;
    int countdown_Secs;

    string btn_30Mins = string.Empty;
    string btn_15Mins = string.Empty;
    string btn_1Hr = string.Empty;
    string btn_StartPause = "border:solid lightgrey 1px";

    string ui_BtnSelected = "color: black; background-color: #28c7fc";
    string ui_Btn = "border:solid lightgrey 1px";

    private bool bElementDisabled = false;

    protected override void OnInitialized()
    {
        SelectDuration(selectedDuration);
    }

    // Timer Methods
    private void StartTimer()
    {
        try
        {
            if (!_timerService.PauseTimer(timer))
            {
                bElementDisabled = false;
                btn_StartPause = ui_Btn;
                return;
            }

            btn_StartPause = ui_BtnSelected;
            bElementDisabled = true;

            timer = new Timer(1000);

            // Call the NewTick method every second.
            timer.Elapsed += NewTick;
            timer.Enabled = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"StartTimer ex: {ex.Message}");
        }
    }

    private void NewTick(Object source, ElapsedEventArgs e)
    {
        bool bUpdateDisplay = false;

        if (countdown_Secs > 0)
        {
            bUpdateDisplay = true;
            countdown_Secs -= 1;
        }
        else
        {
            bUpdateDisplay = true;
            countdown_Secs = 59;
            if (countdown_Hrs > 0 && countdown_Mins == 0)
            {
                countdown_Mins = 59;
            }
            else
            {
                countdown_Mins -= 1;
            }
        }

        if (countdown_Hrs > 0 && countdown_Mins == 59 && countdown_Secs == 59)
        {
            countdown_Hrs -= 1;
            bUpdateDisplay = true;
        }

        if (countdown_Hrs == 0 && countdown_Mins == 0 && countdown_Secs == 0)
        {

            ResetTimer();
            _timerService.DisplayNotification("Timmer done");
        }

        if (bUpdateDisplay) { InvokeAsync(StateHasChanged); }
    }

    private void SelectDuration(int duration)
    {
        selectedDuration = duration;
        setDuration_Secs = 0;

        btn_30Mins = ui_Btn;
        btn_15Mins = ui_Btn;
        btn_1Hr = ui_Btn;

    switch (duration)
        {
            case 0:
                setDuration_Hrs = 0;
                setDuration_Mins = 15;
                countdown_Hrs = 0;
                countdown_Mins = 15;
                countdown_Secs = 0;

                btn_15Mins = ui_BtnSelected;
                break;
            case 1:
                setDuration_Hrs = 0;
                setDuration_Mins = 30;
                countdown_Hrs = 0;
                countdown_Mins = 30;
                countdown_Secs = 0;

                btn_30Mins = ui_BtnSelected;
                break;
            case 2:
                setDuration_Hrs = 1;
                setDuration_Mins = 0;
                countdown_Hrs = 1;
                countdown_Mins = 0;
                countdown_Secs = 0;

                btn_1Hr = ui_BtnSelected;
                break;
        }
    }

    private void ResetTimer()
    {
        try
        {
            btn_StartPause = ui_Btn;
            _timerService.TimerCleanUp(timer);
            SelectDuration(selectedDuration);
            
            bElementDisabled = false;
            InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ResetTimer ex: {ex.Message}");
        }
    }
}